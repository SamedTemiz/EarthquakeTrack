---
import PageLayout from '../layouts/PageLayout.astro';

interface RelatedPost {
  href: string;
  title: string;
}

interface Props {
  title: string;
  description: string;
  canonical: string;
  heading: string;
  headingEn?: string;
  date: string;
  dateEn?: string;
  readTime: string;
  related?: RelatedPost[];
  relatedEn?: RelatedPost[];
}

const { title, description, canonical, heading, headingEn, date, dateEn, readTime, related = [], relatedEn = [] } = Astro.props;
const readMinutes = readTime.replace(/\D/g, '');
---
<PageLayout
  title={title}
  description={description}
  canonical={canonical}
  activePage="blog"
>
  <Fragment slot="head">
    <style is:global>
      /* ── Article shell ─────────────────────────────────────────── */
      .edu-shell { display:flex; flex-direction:column; min-height:100%; }
      .edu-header { padding:36px 48px 28px; border-bottom:1px solid var(--border-color); background:linear-gradient(160deg,rgba(197,160,101,.07) 0%,transparent 65%); flex-shrink:0; }
      .edu-header h1 { margin:0 0 0; font-size:clamp(1.6rem,3vw,2.2rem); font-weight:700; color:var(--accent-gold); letter-spacing:-.02em; line-height:1.25; }
      .blog-post-meta { display:flex; align-items:center; gap:12px; font-size:.88rem; color:var(--text-tertiary); margin-bottom:14px; }
      .edu-body { padding:28px 48px 56px; flex:1; }
      .article-content { max-width:800px; }
      .article-content h2 { font-size:1.4rem; color:var(--text-primary); margin:34px 0 15px; }
      .article-content h3 { font-size:1.15rem; color:var(--text-secondary); margin:25px 0 10px; }
      .article-content p { margin:0 0 20px; color:var(--text-secondary); line-height:1.75; }
      .article-content ul, .article-content ol { margin:0 0 25px 20px; color:var(--text-secondary); line-height:1.7; }
      .article-content li { margin-bottom:10px; }
      .article-content strong { color:var(--accent-gold); }
      .article-content table { width:100%; border-collapse:collapse; margin:0 0 25px; font-size:.92rem; }
      .article-content th, .article-content td { border:1px solid var(--border-color); padding:10px 12px; text-align:left; color:var(--text-secondary); }
      .article-content th { background:rgba(197,160,101,.08); color:var(--text-primary); font-weight:600; }

      /* ── Callout boxes ─────────────────────────────────────────── */
      .callout { display:flex; gap:12px; padding:16px 18px; border-radius:10px; margin:0 0 22px; font-size:.93rem; line-height:1.65; border:1px solid; }
      .callout svg { flex-shrink:0; width:20px; height:20px; margin-top:2px; }
      .article-content .callout p { margin:0; }
      .callout.warn { border-color:rgba(220,80,80,.35); background:rgba(220,80,80,.07); }
      .callout.warn svg { stroke:#e06c6c; }
      .callout.ok { border-color:rgba(80,200,120,.3); background:rgba(80,200,120,.06); }
      .callout.ok svg { stroke:#5dc97a; }
      .callout.info { border-color:rgba(197,160,101,.35); background:rgba(197,160,101,.07); }
      .callout.info svg { stroke:var(--accent-gold); }

      /* ── Roadmap (connected icon stepper) ──────────────────────── */
      .roadmap { position:relative; margin:10px 0 30px; padding-left:8px; }
      .roadmap::before { content:''; position:absolute; left:35px; top:28px; bottom:28px; width:2px; background:linear-gradient(to bottom, rgba(197,160,101,.55), rgba(197,160,101,.15)); }
      .roadmap-step { position:relative; display:flex; gap:20px; padding:0 0 34px; }
      .roadmap-step:last-child { padding-bottom:6px; }
      .roadmap-marker { flex-shrink:0; display:flex; flex-direction:column; align-items:center; gap:8px; width:56px; }
      .roadmap-icon { position:relative; z-index:1; width:56px; height:56px; border-radius:50%; display:flex; align-items:center; justify-content:center; background:var(--card-bg); border:2px solid var(--accent-gold); color:var(--accent-gold); }
      .roadmap-icon svg { width:24px; height:24px; }
      .roadmap-step:nth-child(1) .roadmap-icon { animation:rm-pulse 3s ease-out infinite; }
      .roadmap-step:nth-child(2) .roadmap-icon { animation:rm-pulse 3s ease-out .5s infinite; }
      .roadmap-step:nth-child(3) .roadmap-icon { animation:rm-pulse 3s ease-out 1s infinite; }
      .roadmap-step:nth-child(4) .roadmap-icon { animation:rm-pulse 3s ease-out 1.5s infinite; }
      .roadmap-step:nth-child(5) .roadmap-icon { animation:rm-pulse 3s ease-out 2s infinite; }
      .roadmap-step:nth-child(6) .roadmap-icon { animation:rm-pulse 3s ease-out 2.5s infinite; }
      .roadmap-step.final .roadmap-icon { border-color:#5dc97a; color:#5dc97a; }
      @keyframes rm-pulse {
        0%   { box-shadow:0 0 0 0 rgba(197,160,101,.35); }
        60%  { box-shadow:0 0 0 14px rgba(197,160,101,0); }
        100% { box-shadow:0 0 0 0 rgba(197,160,101,0); }
      }
      /* Pill with a solid background so the connector line never shows through the label */
      .roadmap-time { position:relative; z-index:1; font-size:.68rem; font-weight:700; letter-spacing:.03em; color:var(--accent-gold); text-align:center; white-space:nowrap; background:var(--card-bg); border:1px solid rgba(197,160,101,.35); border-radius:10px; padding:3px 8px; }
      .roadmap-step.final .roadmap-time { color:#5dc97a; border-color:rgba(80,200,120,.35); }
      .roadmap-body { flex:1; min-width:0; padding-top:6px; }
      .roadmap-body h3 { margin:0 0 8px !important; font-size:1.08rem !important; color:var(--text-primary) !important; }
      .roadmap-body p { margin-bottom:10px !important; font-size:.93rem; }
      .roadmap-body ul { margin:0 0 6px 18px !important; font-size:.92rem; }
      .roadmap-body li { margin-bottom:6px !important; }

      /* ── History timeline ──────────────────────────────────────── */
      .htl { position:relative; margin:10px 0 30px; padding-left:8px; }
      .htl::before { content:''; position:absolute; left:46px; top:20px; bottom:20px; width:2px; background:linear-gradient(to bottom, rgba(197,160,101,.5), rgba(197,160,101,.12)); }
      .htl-item { position:relative; display:flex; gap:22px; padding:0 0 30px; }
      .htl-item:last-child { padding-bottom:4px; }
      .htl-year { position:relative; z-index:1; flex-shrink:0; width:78px; height:34px; display:flex; align-items:center; justify-content:center; border-radius:17px; background:var(--card-bg); border:2px solid var(--accent-gold); color:var(--accent-gold); font-weight:700; font-size:.85rem; }
      .htl-item.major .htl-year { background:var(--accent-gold); color:#14161c; }
      .htl-body h3 { margin:5px 0 6px !important; font-size:1.05rem !important; color:var(--text-primary) !important; }
      .htl-body p { margin-bottom:8px !important; font-size:.93rem; }
      .htl-tags { display:flex; flex-wrap:wrap; gap:8px; margin-bottom:4px; }
      .htl-tag { font-size:.72rem; font-weight:600; padding:3px 10px; border-radius:20px; border:1px solid var(--border-color); color:var(--text-tertiary); }
      .htl-tag.mag { border-color:rgba(220,80,80,.4); color:#e06c6c; }

      /* ── Scenario / info cards ─────────────────────────────────── */
      .vis-grid { display:grid; grid-template-columns:repeat(auto-fill,minmax(240px,1fr)); gap:14px; margin:6px 0 28px; }
      .vis-card { border:1px solid var(--border-color); border-radius:12px; padding:18px; background:rgba(197,160,101,.03); transition:border-color .2s, transform .2s; }
      .vis-card:hover { border-color:rgba(197,160,101,.4); transform:translateY(-2px); }
      .vis-card-icon { width:42px; height:42px; border-radius:10px; display:flex; align-items:center; justify-content:center; background:rgba(197,160,101,.12); color:var(--accent-gold); margin-bottom:12px; }
      .vis-card-icon svg { width:22px; height:22px; }
      .vis-card h3 { margin:0 0 8px !important; font-size:.98rem !important; color:var(--text-primary) !important; }
      .vis-card p { margin:0 !important; font-size:.88rem; line-height:1.6; }

      /* ── Do / Don't columns ────────────────────────────────────── */
      .dd-grid { display:grid; grid-template-columns:1fr 1fr; gap:14px; margin:6px 0 28px; }
      @media (max-width:640px) { .dd-grid { grid-template-columns:1fr; } }
      .dd-col { border-radius:12px; padding:18px; border:1px solid; }
      .dd-col.do { border-color:rgba(80,200,120,.3); background:rgba(80,200,120,.05); }
      .dd-col.dont { border-color:rgba(220,80,80,.3); background:rgba(220,80,80,.05); }
      .dd-col h3 { margin:0 0 12px !important; font-size:.95rem !important; display:flex; align-items:center; gap:8px; }
      .dd-col.do h3 { color:#5dc97a !important; }
      .dd-col.dont h3 { color:#e06c6c !important; }
      .dd-col ul { margin:0 0 0 2px !important; list-style:none; }
      .dd-col li { position:relative; padding-left:24px; margin-bottom:9px !important; font-size:.89rem; line-height:1.55; }
      .dd-col.do li::before { content:'✓'; position:absolute; left:0; color:#5dc97a; font-weight:700; }
      .dd-col.dont li::before { content:'✕'; position:absolute; left:0; color:#e06c6c; font-weight:700; }

      /* ── Magnitude scale bars ──────────────────────────────────── */
      .mag-scale { margin:6px 0 28px; display:flex; flex-direction:column; gap:10px; }
      .mag-row { display:flex; align-items:center; gap:12px; }
      .mag-label { flex-shrink:0; width:64px; font-size:.82rem; font-weight:700; color:var(--text-primary); text-align:right; }
      .mag-track { flex:1; height:26px; border-radius:6px; background:var(--border-color); overflow:hidden; }
      .mag-bar { height:100%; border-radius:6px; display:flex; align-items:center; padding-left:10px; font-size:.72rem; font-weight:600; color:#14161c; white-space:nowrap; transform-origin:left; animation:mag-grow 1.1s cubic-bezier(.25,.7,.3,1) both; }
      .mag-row:nth-child(2) .mag-bar { animation-delay:.12s; }
      .mag-row:nth-child(3) .mag-bar { animation-delay:.24s; }
      .mag-row:nth-child(4) .mag-bar { animation-delay:.36s; }
      .mag-row:nth-child(5) .mag-bar { animation-delay:.48s; }
      .mag-row:nth-child(6) .mag-bar { animation-delay:.6s; }
      @keyframes mag-grow { from { transform:scaleX(0); } to { transform:scaleX(1); } }

      /* ── Stat band ─────────────────────────────────────────────── */
      .stat-band { display:flex; flex-wrap:wrap; gap:14px; margin:6px 0 28px; }
      .stat { flex:1; min-width:130px; border:1px solid var(--border-color); border-radius:12px; padding:18px 16px; text-align:center; background:rgba(197,160,101,.03); }
      .stat-num { display:block; font-size:1.7rem; font-weight:800; color:var(--accent-gold); letter-spacing:-.02em; margin-bottom:4px; }
      .stat-label { font-size:.78rem; color:var(--text-tertiary); line-height:1.4; }

      /* ── ÇKT (Çök-Kapan-Tutun) step row ────────────────────────── */
      .ckt-row { display:grid; grid-template-columns:1fr auto 1fr auto 1fr; align-items:stretch; gap:10px; margin:6px 0 28px; }
      @media (max-width:640px) { .ckt-row { grid-template-columns:1fr; } .ckt-arrow { transform:rotate(90deg); justify-self:center; } }
      .ckt-step { border:1px solid rgba(197,160,101,.35); border-radius:12px; padding:18px 14px; text-align:center; background:rgba(197,160,101,.05); }
      .ckt-step .num { display:inline-flex; align-items:center; justify-content:center; width:30px; height:30px; border-radius:50%; background:var(--accent-gold); color:#14161c; font-weight:800; font-size:.9rem; margin-bottom:10px; }
      .ckt-step h3 { margin:0 0 6px !important; font-size:1rem !important; color:var(--accent-gold) !important; }
      .ckt-step p { margin:0 !important; font-size:.84rem; line-height:1.55; }
      .ckt-arrow { display:flex; align-items:center; color:var(--accent-gold); opacity:.6; }

      /* ── Back link ────────────────────────────────────────────── */
      .article-back-link { display:inline-flex; align-items:center; gap:6px; font-size:.85rem; font-weight:500; color:var(--text-tertiary); text-decoration:none; margin-bottom:18px; padding:4px 0; transition:color .15s, gap .2s; }
      .article-back-link:hover { color:var(--accent-gold); gap:2px; }
      .article-back-link svg { flex-shrink:0; width:16px; height:16px; transition:transform .2s cubic-bezier(0.16,1,0.3,1); }
      .article-back-link:hover svg { transform:translateX(-4px); }

      /* ── Related posts ─────────────────────────────────────────── */
      .related-posts { margin-top:36px; padding-top:22px; border-top:1px solid var(--border-color); }
      .related-posts h2 { font-size:1.05rem !important; margin:0 0 14px !important; color:var(--text-tertiary) !important; text-transform:uppercase; letter-spacing:.06em; font-weight:600; }
      .related-posts a { display:block; padding:13px 16px; margin-bottom:10px; border:1px solid var(--border-color); border-radius:10px; color:var(--text-primary); text-decoration:none; font-size:.93rem; font-weight:500; transition:border-color .2s, background .2s; }
      .related-posts a:hover { border-color:rgba(197,160,101,.45); background:rgba(197,160,101,.05); }

      @media (max-width:600px) {
        .edu-header, .edu-body { padding:16px; }
        /* Browser default list padding (40px) is too deep on small screens */
        .article-content ul, .article-content ol { margin-left:0; padding-left:20px; }
        .roadmap-body ul { margin-left:0 !important; padding-left:16px; }
        /* Roadmap: smaller markers, line stays centered under them */
        .roadmap { padding-left:0; }
        .roadmap::before { left:21px; }
        .roadmap-step { gap:14px; padding-bottom:26px; }
        .roadmap-marker { width:44px; }
        .roadmap-icon { width:44px; height:44px; }
        .roadmap-icon svg { width:19px; height:19px; }
        .roadmap-time { font-size:.62rem; padding:2px 6px; }
        /* History timeline: narrower year pills */
        .htl { padding-left:0; }
        .htl::before { left:30px; }
        .htl-item { gap:14px; }
        .htl-year { width:62px; height:30px; font-size:.78rem; }
        /* Magnitude bars: tighter labels, smaller in-bar text */
        .mag-label { width:46px; font-size:.74rem; }
        .mag-bar { font-size:.6rem; padding-left:6px; }
        /* Tables scroll horizontally instead of overflowing */
        .article-content table { display:block; overflow-x:auto; white-space:nowrap; }
        .stat-band { gap:10px; }
        .stat { min-width:calc(50% - 10px); padding:14px 10px; }
        .stat-num { font-size:1.4rem; }
      }
      @media (prefers-reduced-motion: reduce) {
        .roadmap-icon, .mag-bar { animation:none !important; }
      }
    </style>
  </Fragment>

  <div id="content-tr" class="edu-shell">
    <header class="edu-header">
      <a href="/blog.html" class="article-back-link">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M19 12H5"/><path d="m12 19-7-7 7-7"/>
        </svg>
        Blog &amp; Haberler
      </a>
      <div class="blog-post-meta">
        <span>{date}</span>
        <span>•</span>
        <span>Okuma Süresi: {readTime}</span>
      </div>
      <h1>{heading}</h1>
    </header>
    <div class="edu-body article-content">
      <slot />
      {related.length > 0 && (
        <nav class="related-posts">
          <h2>İlgili Yazılar</h2>
          {related.map(r => <a href={r.href}>{r.title}</a>)}
        </nav>
      )}
    </div>
  </div>

  <div id="content-en" class="edu-shell" style="display:none;">
    <header class="edu-header">
      <a href="/blog.html" class="article-back-link">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M19 12H5"/><path d="m12 19-7-7 7-7"/>
        </svg>
        Blog &amp; News
      </a>
      <div class="blog-post-meta">
        <span>{dateEn ?? date}</span>
        <span>•</span>
        <span>Reading Time: {readMinutes} Min</span>
      </div>
      <h1>{headingEn ?? heading}</h1>
    </header>
    <div class="edu-body article-content">
      <slot name="en" />
      {relatedEn.length > 0 && (
        <nav class="related-posts">
          <h2>Related Posts</h2>
          {relatedEn.map(r => <a href={r.href}>{r.title}</a>)}
        </nav>
      )}
    </div>
  </div>
</PageLayout>

---
import { ClientRouter } from 'astro:transitions';

interface Props {
  title: string;
  description: string;
  canonical: string;
  activePage?: string;
  bodyClass?: string;
}
const { title, description, canonical, bodyClass = '' } = Astro.props;
---
<!DOCTYPE html>
<html lang="tr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{title}</title>
  <meta name="description" content={description}>
  <meta name="robots" content="index, follow">
  <link rel="canonical" href={canonical}>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap">
  <link rel="stylesheet" href="/style.css?v=2036">
  <link rel="icon" href="/favicon.svg" type="image/svg+xml" sizes="any">
  <script is:inline>
    (function(){ document.documentElement.setAttribute('data-theme', localStorage.getItem('theme') || 'dark'); })();
  </script>
  <ClientRouter />
  <slot name="head" />
</head>
<body class={bodyClass}>
  <div class="dashboard-container static-layout">

    <!-- Sidebar: transition:persist keeps it alive across ClientRouter navigations -->
    <aside class="sidebar" transition:persist="sidebar">
      <div class="logo-area" style="position:relative;">
        <div style="display:flex; justify-content:space-between; align-items:center; gap:20px;">
          <h1><a href="/index.html" style="text-decoration:none; color:inherit;">Earthquake<span>Track</span></a></h1>
          <div class="controls" style="display:flex; align-items:center; gap:8px;">
            <button id="theme-toggle-btn" class="icon-btn" aria-label="Tema değiştir">
              <svg class="icon-sun" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="12" r="5"></circle><line x1="12" y1="1" x2="12" y2="3"></line><line x1="12" y1="21" x2="12" y2="23"></line><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"></line><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"></line><line x1="1" y1="12" x2="3" y2="12"></line><line x1="21" y1="12" x2="23" y2="12"></line><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"></line><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"></line>
              </svg>
              <svg class="icon-moon" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path>
              </svg>
            </button>
            <button id="lang-toggle" class="icon-btn" style="font-weight:600; font-size:12px;">EN</button>
            <button id="sidebar-toggle-btn" class="icon-btn">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect><line x1="9" y1="3" x2="9" y2="21"></line>
              </svg>
            </button>
          </div>
        </div>
        <span id="mobile-toggle-icon" class="mobile-toggle-icon" style="position:absolute; left:50%; transform:translateX(-50%); top:0;"></span>
      </div>

      <nav class="main-nav">
        <div class="nav-primary-section">
          <a href="/index.html" class="nav-link-item nav-link-primary" data-tooltip="Deprem Haritası">
            <span class="icon">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <polygon points="1 6 1 22 8 18 16 22 23 18 23 2 16 6 8 2 1 6"></polygon>
                <line x1="8" y1="2" x2="8" y2="18"></line>
                <line x1="16" y1="6" x2="16" y2="22"></line>
              </svg>
            </span>
            <span>Deprem Haritası</span>
          </a>
        </div>
        <div class="nav-divider">BİLGİ MERKEZİ</div>
        <div class="nav-links">
          <a href="/blog.html" class="nav-link-item" data-tooltip="Blog & Haberler">
            <span class="icon">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M4 22h16a2 2 0 0 0 2-2V4a2 2 0 0 0-2-2H8a2 2 0 0 0-2 2v16a2 2 0 0 1-2 2Zm0 0a2 2 0 0 1-2-2v-9c0-1.1.9-2 2-2h2"></path><path d="M18 14h-8"></path><path d="M15 18h-5"></path><path d="M10 6h8v4h-8V6Z"></path>
              </svg>
            </span>
            <span>Blog & Haberler</span>
          </a>
          <a href="/preparedness.html" class="nav-link-item" data-tooltip="Deprem Önlemleri">
            <span class="icon">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path><path d="m9 12 2 2 4-4"></path>
              </svg>
            </span>
            <span>Deprem Önlemleri</span>
          </a>
          <a href="/education.html" class="nav-link-item" data-tooltip="Deprem Eğitimi">
            <span class="icon">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="m4 6 8-4 8 4"></path><path d="m18 10 4 2v8a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2v-8l4-2"></path><path d="M14 22v-4a2 2 0 0 0-2-2v0a2 2 0 0 0-2 2v4"></path><path d="M18 5v17"></path><path d="M6 5v17"></path><circle cx="12" cy="9" r="2"></circle>
              </svg>
            </span>
            <span>Deprem Eğitimi</span>
          </a>
        </div>

      </nav>

      <div class="earthquake-list-container">
        <div id="view-active-issues" class="view-section active">
          <div class="list-header">
            <h3 data-i18n="recentActivity">Son Hareketler</h3>
            <div style="display:flex;align-items:center;gap:5px;">
              <button id="refresh-btn" class="icon-btn" title="Yenile">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M21.5 2v6h-6M2.5 22v-6h6M2 11.5a10 10 0 0 1 18.8-4.3M22 12.5a10 10 0 0 1-18.8 4.3"/>
                </svg>
              </button>
              <span class="badge" data-i18n="live">Canlı</span>
            </div>
          </div>
          <div class="location-selector">
            <div class="location-field">
              <label for="country-select" class="location-label" data-i18n="country">Ülke</label>
              <select id="country-select" class="location-select" aria-label="Country">
                <option value="" data-i18n="allCountries">Tüm ülkeler</option>
              </select>
            </div>
            <div class="location-field">
              <label for="city-select" class="location-label location-label-city" data-i18n="city">Şehir</label>
              <select id="city-select" class="location-select" aria-label="City" disabled>
                <option value="" data-i18n="allCities">Tüm şehirler</option>
              </select>
            </div>
          </div>
          <div id="earthquake-list" class="earthquake-list"></div>
        </div>
      </div>

      <div class="sidebar-footer">
        <div class="footer-row">
          <a href="/about.html" data-i18n="about">Hakkında</a>
          <a href="/faq.html" data-i18n="faq">SSS</a>
          <a href="/contact.html" data-i18n="contact">İletişim</a>
        </div>
        <div class="footer-row">
          <a href="/privacy.html" data-i18n="privacy">Gizlilik Politikası</a>
          <a href="/terms.html" data-i18n="terms">Kullanım Koşulları</a>
        </div>
      </div>
      <div id="sidebar-resizer"></div>
    </aside>

    <!-- Content area: swaps on each navigation -->
    <main class="main-content scrollable" transition:animate="fade">
      <slot />
    </main>

  </div>

  <slot name="scripts" />
  <script is:inline>
    // Sidebar shell: init once — transition:persist keeps it alive across navigations
    document.addEventListener('astro:page-load', function initShell() {
      if (window.__shellReady) return;
      window.__shellReady = true;
      import('/js/layout.js');
      import('/js/sidebar-data.js');
    });

    // Update active nav link on every navigation (sidebar HTML persists, active class must follow URL)
    document.addEventListener('astro:page-load', function syncActiveNav() {
      var path = window.location.pathname;
      document.querySelectorAll('.nav-link-item').forEach(function(link) {
        var linkPath = new URL(link.href, window.location.href).pathname;
        link.classList.toggle('active', linkPath === path);
      });
    });

    // Page transition loader
    import('/js/page-transition.js');
  </script>
</body>
</html>

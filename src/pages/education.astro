import PageLayout from '../layouts/PageLayout.astro';
---
<PageLayout
  title="Deprem Bilgisi ve Terimler - EarthquakeTrack"
  description="Deprem büyüklüğü, şiddet, odak derinliği, fay hatları, P ve S dalgaları, Türkiye'nin sismik yapısı ve daha fazlası. Temel sismoloji bilgileri."
  canonical="https://earthquaketrack.com.tr/education.html"
  activePage="education"
  bodyClass="edu-page"
>
  <Fragment slot="head">
    <style>
      .edu-shell { display:flex; flex-direction:column; min-height:100%; }
      .edu-header { padding:36px 48px 28px; border-bottom:1px solid var(--border-color); background:linear-gradient(160deg,rgba(52,152,219,.07) 0%,transparent 65%); flex-shrink:0; }
      .edu-header h1 { margin:0 0 12px; font-size:clamp(1.5rem,2.5vw,2.2rem); font-weight:700; color:var(--accent-gold); letter-spacing:-.025em; line-height:1.2; }
      .edu-lead { margin:0; color:var(--text-secondary); font-size:.97rem; max-width:70ch; line-height:1.65; }
      .edu-body { padding:28px 48px 56px; }
      .edu-section-label { font-size:.7rem; font-weight:700; letter-spacing:.09em; text-transform:uppercase; color:var(--accent-gold); opacity:.7; margin:28px 0 10px; }
      .edu-section-label:first-child { margin-top:0; }
      .edu-term { border:1px solid var(--border-color); border-radius:12px; padding:20px; background:var(--surface-card,var(--card-bg)); transition:border-color .2s,box-shadow .2s; }
      .edu-term:hover { border-color:rgba(197,160,101,.45); box-shadow:0 4px 16px rgba(0,0,0,.1); }
      .edu-term-head { display:flex; align-items:flex-start; gap:14px; margin-bottom:14px; }
      .edu-ico { flex-shrink:0; width:40px; height:40px; border-radius:10px; display:flex; align-items:center; justify-content:center; background:rgba(52,152,219,.12); border:1px solid rgba(52,152,219,.28); color:var(--accent-blue); }
      .edu-ico svg { width:22px; height:22px; stroke:currentColor; fill:none; stroke-width:2; stroke-linecap:round; stroke-linejoin:round; }
      .edu-term h2 { margin:0; font-size:1rem; font-weight:600; color:var(--text-primary); line-height:1.35; }
      .edu-term p { margin:0 0 10px; color:var(--text-secondary); font-size:.92rem; line-height:1.6; }
      .edu-term p:last-child { margin-bottom:0; }
      .edu-term strong { color:var(--text-primary); }

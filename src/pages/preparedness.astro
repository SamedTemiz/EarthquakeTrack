---
import PageLayout from '../layouts/PageLayout.astro';
---
<PageLayout
  title="Deprem Önlemleri ve Deprem Çantası - EarthquakeTrack"
  description="Deprem öncesi, anı ve sonrasında yapılması gerekenler. Deprem çantasında neler bulunmalı? Hayat kurtaran önlemler."
  canonical="https://earthquaketrack.com.tr/preparedness.html"
  activePage="preparedness"
  bodyClass="prep-page"
>
  <Fragment slot="head">
    <style is:global>
      .prep-shell { display:flex; flex-direction:column; min-height:100%; }
      .prep-header { padding:36px 48px 32px; border-bottom:1px solid var(--border-color); background:linear-gradient(160deg,rgba(197,160,101,.07) 0%,transparent 65%); flex-shrink:0; }
      .prep-header h1 { margin:0 0 12px; font-size:clamp(1.5rem,2.5vw,2.2rem); font-weight:700; color:var(--accent-gold); letter-spacing:-.025em; }
      .prep-lead { margin:0; color:var(--text-secondary); font-size:.97rem; max-width:70ch; line-height:1.65; }
      .prep-body { padding:32px 48px 64px; }

      /* Phase nav */
      .prep-phases { display:grid; grid-template-columns:repeat(3,1fr); gap:12px; margin-bottom:40px; }
      .prep-phase { display:flex; align-items:center; gap:12px; padding:14px 18px; border-radius:12px; border:1px solid var(--border-color); background:var(--card-bg); text-decoration:none; transition:border-color .2s,box-shadow .2s; }
      .prep-phase:hover { border-color:rgba(197,160,101,.45); box-shadow:0 4px 16px rgba(0,0,0,.08); }
      .prep-phase-num { flex-shrink:0; width:36px; height:36px; border-radius:50%; font-weight:800; font-size:.95rem; display:flex; align-items:center; justify-content:center; }
      .num-1 { background:rgba(197,160,101,.15); color:var(--accent-gold); }
      .num-2 { background:rgba(255,100,100,.12); color:#ff6b6b; }
      .num-3 { background:rgba(77,255,136,.1); color:var(--accent-green); }
      .prep-phase-label { font-size:.71rem; font-weight:600; letter-spacing:.06em; text-transform:uppercase; color:var(--text-tertiary); }
      .prep-phase-name { font-size:.93rem; font-weight:600; color:var(--text-primary); }

      /* Section */
      .prep-section { margin-bottom:48px; scroll-margin-top:20px; }
      .prep-section:last-of-type { margin-bottom:0; }
      .prep-section-title { display:flex; align-items:center; gap:12px; margin:0 0 22px; padding-bottom:14px; border-bottom:2px solid var(--border-color); }
      .prep-section-icon { flex-shrink:0; width:40px; height:40px; border-radius:10px; display:flex; align-items:center; justify-content:center; }
      .prep-section-icon svg { width:22px; height:22px; stroke:currentColor; fill:none; stroke-width:2; stroke-linecap:round; stroke-linejoin:round; }
      .icon-kit   { background:rgba(197,160,101,.12); border:1px solid rgba(197,160,101,.25); color:var(--accent-gold); }
      .icon-during { background:rgba(255,100,100,.1); border:1px solid rgba(255,100,100,.2); color:#ff6b6b; }
      .icon-after { background:rgba(77,255,136,.1); border:1px solid rgba(77,255,136,.2); color:var(--accent-green); }
      .prep-section-title h2 { margin:0; font-size:1.22rem; font-weight:700; color:var(--text-primary); }

      /* 72h banner */
      .kit-72h { display:flex; align-items:flex-start; gap:10px; padding:12px 16px; background:rgba(197,160,101,.07); border:1px solid rgba(197,160,101,.2); border-radius:10px; font-size:.86rem; color:var(--text-secondary); margin-bottom:16px; }
      .kit-72h-icon { flex-shrink:0; margin-top:1px; }

      /* Kit categories */
      .kit-categories { display:grid; grid-template-columns:repeat(4,1fr); gap:14px; }
      .kit-cat { border:1px solid var(--border-color); border-radius:12px; background:var(--card-bg); padding:18px; transition:border-color .2s; }
      .kit-cat:hover { border-color:rgba(197,160,101,.35); }
      .kit-cat-head { display:flex; align-items:center; gap:8px; margin-bottom:14px; }
      .kit-cat-icon { width:34px; height:34px; border-radius:8px; display:flex; align-items:center; justify-content:center; flex-shrink:0; }
      .kit-cat-icon svg { width:18px; height:18px; stroke:currentColor; fill:none; stroke-width:2; stroke-linecap:round; stroke-linejoin:round; }
      .c-water { background:rgba(52,152,219,.12); color:var(--accent-blue); }
      .c-health { background:rgba(255,100,100,.1); color:#ff6b6b; }
      .c-light  { background:rgba(197,160,101,.12); color:var(--accent-gold); }
      .c-docs   { background:rgba(77,255,136,.1); color:var(--accent-green); }
      .kit-cat-name { font-size:.85rem; font-weight:700; color:var(--text-primary); }
      .kit-items { list-style:none; padding:0; margin:0; display:flex; flex-direction:column; gap:8px; }
      .kit-items li { display:flex; align-items:flex-start; gap:8px; font-size:.86rem; color:var(--text-secondary); line-height:1.45; }
      .kit-bullet { flex-shrink:0; width:6px; height:6px; border-radius:50%; margin-top:6px; }
      .b-water { background:var(--accent-blue); }
      .b-health { background:#ff6b6b; }
      .b-light  { background:var(--accent-gold); }
      .b-docs   { background:var(--accent-green); }

      /* Steps: Çök-Kapan-Tutun */
      .steps-intro { font-size:.95rem; color:var(--text-secondary); margin:0 0 20px; line-height:1.6; }
      .steps-row { display:grid; grid-template-columns:repeat(3,1fr); border:1px solid var(--border-color); border-radius:14px; overflow:hidden; margin-bottom:20px; }
      .step-card { display:flex; flex-direction:column; align-items:center; padding:28px 18px; text-align:center; background:var(--card-bg); border-right:1px solid var(--border-color); }
      .step-card:last-child { border-right:none; }
      .step-num { width:40px; height:40px; border-radius:50%; font-weight:800; font-size:1rem; display:flex; align-items:center; justify-content:center; margin-bottom:14px; border:2px solid; }
      .s1 { background:rgba(197,160,101,.12); color:var(--accent-gold); border-color:rgba(197,160,101,.4); }
      .s2 { background:rgba(52,152,219,.1); color:var(--accent-blue); border-color:rgba(52,152,219,.3); }
      .s3 { background:rgba(77,255,136,.08); color:var(--accent-green); border-color:rgba(77,255,136,.3); }
      .step-visual { width:80px; height:80px; margin-bottom:14px; }
      .step-visual svg { width:80px; height:80px; }
      .step-keyword { font-size:1.25rem; font-weight:800; color:var(--text-primary); margin-bottom:6px; letter-spacing:.02em; }
      .step-sub { font-size:.82rem; color:var(--text-secondary); line-height:1.45; }

      /* Indoor/Outdoor */
      .env-split { display:grid; grid-template-columns:1fr 1fr; gap:12px; }
      .env-card { border:1px solid var(--border-color); border-radius:12px; background:var(--card-bg); padding:20px; }
      .env-card-head { display:flex; align-items:center; gap:10px; margin-bottom:14px; }
      .env-card-icon { width:36px; height:36px; border-radius:9px; display:flex; align-items:center; justify-content:center; flex-shrink:0; }
      .env-card-icon svg { width:20px; height:20px; stroke:currentColor; fill:none; stroke-width:2; stroke-linecap:round; stroke-linejoin:round; }
      .e-indoor  { background:rgba(52,152,219,.1); color:var(--accent-blue); }
      .e-outdoor { background:rgba(77,255,136,.1); color:var(--accent-green); }
      .env-card-head h3 { margin:0; font-size:.97rem; font-weight:700; color:var(--text-primary); }
      .env-list { list-style:none; padding:0; margin:0; display:flex; flex-direction:column; gap:9px; }
      .env-list li { display:flex; align-items:flex-start; gap:9px; font-size:.88rem; color:var(--text-secondary); line-height:1.5; }
      .env-check { flex-shrink:0; width:18px; height:18px; border-radius:50%; display:flex; align-items:center; justify-content:center; margin-top:1px; }
      .env-check svg { width:10px; height:10px; stroke:currentColor; fill:none; stroke-width:3; stroke-linecap:round; stroke-linejoin:round; }
      .ec-blue  { background:rgba(52,152,219,.15); color:var(--accent-blue); }
      .ec-green { background:rgba(77,255,136,.12); color:var(--accent-green); }

      /* After checklist */
      .after-list { display:flex; flex-direction:column; gap:10px; }
      .after-item { display:flex; align-items:flex-start; gap:14px; padding:16px 18px; border-radius:12px; border:1px solid var(--border-color); background:var(--card-bg); transition:border-color .18s; }
      .after-item:hover { border-color:rgba(77,255,136,.35); }
      .after-badge { flex-shrink:0; width:34px; height:34px; border-radius:50%; background:rgba(77,255,136,.1); border:1px solid rgba(77,255,136,.22); color:var(--accent-green); display:flex; align-items:center; justify-content:center; margin-top:1px; }
      .after-badge svg { width:16px; height:16px; stroke:currentColor; fill:none; stroke-width:2.5; stroke-linecap:round; stroke-linejoin:round; }
      .after-text strong { display:block; font-size:.94rem; font-weight:600; color:var(--text-primary); margin-bottom:3px; }
      .after-text span { font-size:.85rem; color:var(--text-secondary); line-height:1.5; }

      .prep-citation { margin-top:40px; padding-top:18px; border-top:1px solid var(--border-color); font-size:.8rem; color:var(--text-tertiary); }
      body.prep-page a[href^="http"] { color:var(--accent-blue); text-decoration:none; font-weight:500; }
      body.prep-page a[href^="http"]:hover { text-decoration:underline; }

      @media (max-width:900px) {
        .prep-header { padding:24px 28px 24px; }
        .prep-body { padding:24px 28px 48px; }
        .kit-categories { grid-template-columns:repeat(2,1fr); }
      }
      @media (max-width:600px) {
        .prep-header { padding:20px 16px 16px; }
        .prep-body { padding:16px 16px 40px; }
        .prep-phases { grid-template-columns:1fr; gap:8px; margin-bottom:24px; }
        .prep-phase { padding:12px 14px; }
        .kit-categories { grid-template-columns:1fr 1fr; gap:10px; }
        .kit-cat { padding:14px; }
        .steps-row { grid-template-columns:1fr; border-radius:10px; }
        .step-card { border-right:none; border-bottom:1px solid var(--border-color); padding:20px 16px; }
        .step-card:last-child { border-bottom:none; }
        .env-split { grid-template-columns:1fr; }
        .prep-section { margin-bottom:32px; }
        .prep-section-title { margin-bottom:16px; }
      }
    </style>
  </Fragment>

  <div class="prep-shell">

    <!-- ── TÜRKÇE ── -->
    <div id="content-tr">
      <header class="prep-header">
        <h1>Deprem Önlemleri</h1>
        <p class="prep-lead">Deprem önlenemez; doğru hazırlık ve davranışlarla riskleri azaltabilirsiniz. Aşağıdaki adımlar bilgilendirme amaçlıdır; resmi kurum duyurularını takip edin.</p>
      </header>
      <div class="prep-body">

        <!-- Phase nav -->
        <div class="prep-phases">
          <a href="#kit-tr" class="prep-phase">
            <span class="prep-phase-num num-1">1</span>
            <div>
              <div class="prep-phase-label">Aşama 1 — Önce</div>
              <div class="prep-phase-name">Deprem Çantası</div>
            </div>
          </a>
          <a href="#during-tr" class="prep-phase">
            <span class="prep-phase-num num-2">2</span>
            <div>
              <div class="prep-phase-label">Aşama 2 — Anında</div>
              <div class="prep-phase-name">Doğru Davranış</div>
            </div>
          </a>
          <a href="#after-tr" class="prep-phase">
            <span class="prep-phase-num num-3">3</span>
            <div>
              <div class="prep-phase-label">Aşama 3 — Sonrası</div>
              <div class="prep-phase-name">Güvenli Toparlanma</div>
            </div>
          </a>
        </div>

        <!-- 1. Deprem çantası -->
        <section class="prep-section" id="kit-tr">
          <div class="prep-section-title">
            <span class="prep-section-icon icon-kit" aria-hidden="true">
              <svg viewBox="0 0 24 24"><path d="M4 10a2 2 0 012-2h12a2 2 0 012 2v9a2 2 0 01-2 2H6a2 2 0 01-2-2v-9z"/><path d="M8 8V6a4 4 0 118 0v2"/></svg>
            </span>
            <h2>Deprem Çantası Hazırlığı</h2>
          </div>
          <div class="kit-72h">
            <span class="kit-72h-icon">⚠️</span>
            <span>İlk <strong>72 saat</strong> içinde yardım gecikebilir. Tüm malzemeleri tek bir çantada hazır bulundurun.</span>
          </div>
          <div class="kit-categories" role="list">
            <div class="kit-cat" role="listitem">
              <div class="kit-cat-head">
                <span class="kit-cat-icon c-water" aria-hidden="true"><svg viewBox="0 0 24 24"><path d="M12 22a7 7 0 007-7c0-5-7-13-7-13S5 10 5 15a7 7 0 007 7z"/></svg></span>
                <span class="kit-cat-name">Su &amp; Gıda</span>
              </div>
              <ul class="kit-items">
                <li><span class="kit-bullet b-water"></span>Kişi başı en az 1 litre su</li>
                <li><span class="kit-bullet b-water"></span>Konserve yiyecekler</li>
                <li><span class="kit-bullet b-water"></span>Enerji bar / bisküvi</li>
                <li><span class="kit-bullet b-water"></span>Su arıtma tableti</li>
              </ul>
            </div>
            <div class="kit-cat" role="listitem">
              <div class="kit-cat-head">
                <span class="kit-cat-icon c-health" aria-hidden="true"><svg viewBox="0 0 24 24"><path d="M22 12h-4l-3 9L9 3l-3 9H2"/></svg></span>
                <span class="kit-cat-name">Sağlık &amp; İlaç</span>
              </div>
              <ul class="kit-items">
                <li><span class="kit-bullet b-health"></span>İlk yardım çantası</li>
                <li><span class="kit-bullet b-health"></span>Düzenli ilaçlar (7 günlük)</li>
                <li><span class="kit-bullet b-health"></span>Yedek gözlük / lens</li>
                <li><span class="kit-bullet b-health"></span>Maske ve eldiven</li>
              </ul>
            </div>
            <div class="kit-cat" role="listitem">
              <div class="kit-cat-head">
                <span class="kit-cat-icon c-light" aria-hidden="true"><svg viewBox="0 0 24 24"><path d="M10 2h4v5l-1 1h-2l-1-1V2z"/><path d="M12 9v13M9 22h6"/></svg></span>
                <span class="kit-cat-name">Işık &amp; İletişim</span>
              </div>
              <ul class="kit-items">
                <li><span class="kit-bullet b-light"></span>Fener ve yedek pil</li>
                <li><span class="kit-bullet b-light"></span>Powerbank (şarjlı)</li>
                <li><span class="kit-bullet b-light"></span>Düdük</li>
                <li><span class="kit-bullet b-light"></span>Yedek çakmak / kibrit</li>
              </ul>
            </div>
            <div class="kit-cat" role="listitem">
              <div class="kit-cat-head">
                <span class="kit-cat-icon c-docs" aria-hidden="true"><svg viewBox="0 0 24 24"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><path d="M14 2v6h6M16 13H8M16 17H8M10 9H8"/></svg></span>
                <span class="kit-cat-name">Belgeler &amp; Nakit</span>
              </div>
              <ul class="kit-items">
                <li><span class="kit-bullet b-docs"></span>Kimlik / pasaport fotokopisi</li>
                <li><span class="kit-bullet b-docs"></span>Sigorta belgeleri</li>
                <li><span class="kit-bullet b-docs"></span>Acil nakit para</li>
                <li><span class="kit-bullet b-docs"></span>Aile toplanma noktası notu</li>
              </ul>
            </div>
          </div>
        </section>

        <!-- 2. Deprem anında -->
        <section class="prep-section" id="during-tr">
          <div class="prep-section-title">
            <span class="prep-section-icon icon-during" aria-hidden="true">
              <svg viewBox="0 0 24 24"><path d="M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"/><path d="M12 9v4M12 17h.01"/></svg>
            </span>
            <h2>Deprem Anında</h2>
          </div>
          <p class="steps-intro">Sarsıntı başladığı anda panik yapmayın. Dünyada kabul gören <strong>Çök — Kapan — Tutun</strong> yöntemini uygulayın.</p>

          <div class="steps-row" role="list">
            <!-- Step 1: Çök -->
            <div class="step-card" role="listitem">
              <div class="step-num s1">1</div>
              <div class="step-visual" aria-hidden="true">
                <svg viewBox="0 0 80 80" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" style="color:var(--accent-gold)">
                  <circle cx="40" cy="13" r="7"/>
                  <path d="M40 20 Q37 32 34 42"/>
                  <path d="M37 29 L18 38"/>
                  <path d="M37 29 L56 36"/>
                  <path d="M34 42 L22 58"/>
                  <path d="M34 42 L48 56"/>
                  <line x1="8" y1="64" x2="72" y2="64" stroke-width="1.5" stroke-dasharray="4 3"/>
                  <path d="M10 18 L10 30 M6 26 L10 30 L14 26" stroke-width="1.8"/>
                  <path d="M70 18 L70 30 M66 26 L70 30 L74 26" stroke-width="1.8"/>
                </svg>
              </div>
              <div class="step-keyword">ÇÖK</div>
              <div class="step-sub">Dizlerinizin üzerine hemen yere çökün</div>
            </div>
            <!-- Step 2: Kapan -->
            <div class="step-card" role="listitem">
              <div class="step-num s2">2</div>
              <div class="step-visual" aria-hidden="true">
                <svg viewBox="0 0 80 80" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" style="color:var(--accent-blue)">
                  <rect x="10" y="20" width="60" height="7" rx="2"/>
                  <line x1="16" y1="27" x2="16" y2="60"/>
                  <line x1="64" y1="27" x2="64" y2="60"/>
                  <circle cx="40" cy="38" r="7"/>
                  <path d="M33 34 Q25 26 23 32"/>
                  <path d="M47 34 Q55 26 57 32"/>
                  <path d="M40 45 L38 58"/>
                  <path d="M40 45 L43 58"/>
                  <line x1="8" y1="64" x2="72" y2="64" stroke-width="1.5" stroke-dasharray="4 3"/>
                </svg>
              </div>
              <div class="step-keyword">KAPAN</div>
              <div class="step-sub">Başınızı kollarınızla kapatın</div>
            </div>
            <!-- Step 3: Tutun -->
            <div class="step-card" role="listitem">
              <div class="step-num s3">3</div>
              <div class="step-visual" aria-hidden="true">
                <svg viewBox="0 0 80 80" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" style="color:var(--accent-green)">
                  <rect x="10" y="20" width="60" height="7" rx="2"/>
                  <line x1="16" y1="27" x2="16" y2="60"/>
                  <line x1="64" y1="27" x2="64" y2="60"/>
                  <circle cx="34" cy="38" r="7"/>
                  <path d="M34 45 L32 58"/>
                  <path d="M34 45 L37 58"/>
                  <path d="M27 35 L16 28" stroke-width="2.8"/>
                  <path d="M27 41 L16 41" stroke-width="2.8"/>
                  <circle cx="16" cy="28" r="3.5"/>
                  <circle cx="16" cy="41" r="3.5"/>
                  <path d="M62 32 Q68 29 66 36 Q64 43 70 41" stroke-width="1.4"/>
                  <line x1="8" y1="64" x2="72" y2="64" stroke-width="1.5" stroke-dasharray="4 3"/>
                </svg>
              </div>
              <div class="step-keyword">TUTUN</div>
              <div class="step-sub">Sarsıntı bitene kadar sağlam bir yere tutunun</div>
            </div>
          </div>

          <div class="env-split">
            <div class="env-card">
              <div class="env-card-head">
                <span class="env-card-icon e-indoor" aria-hidden="true">
                  <svg viewBox="0 0 24 24"><path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/><path d="M9 22V12h6v10"/></svg>
                </span>
                <h3>Bina İçindeyseniz</h3>
              </div>
              <ul class="env-list">
                <li><span class="env-check ec-blue" aria-hidden="true"><svg viewBox="0 0 12 12"><polyline points="1,6 4,9 11,3"/></svg></span><span>Çök-Kapan-Tutun; sağlam mobilyanın yanına geçin</span></li>
                <li><span class="env-check ec-blue" aria-hidden="true"><svg viewBox="0 0 12 12"><polyline points="1,6 4,9 11,3"/></svg></span><span>Pencere ve balkona <strong>yaklaşmayın</strong></span></li>
                <li><span class="env-check ec-blue" aria-hidden="true"><svg viewBox="0 0 12 12"><polyline points="1,6 4,9 11,3"/></svg></span><span>Asansör ve merdivenlerden uzak durun</span></li>
                <li><span class="env-check ec-blue" aria-hidden="true"><svg viewBox="0 0 12 12"><polyline points="1,6 4,9 11,3"/></svg></span><span>Sarsıntı bitmeden binayı terk etmeyin</span></li>
              </ul>
            </div>
            <div class="env-card">
              <div class="env-card-head">
                <span class="env-card-icon e-outdoor" aria-hidden="true">
                  <svg viewBox="0 0 24 24"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
                </span>
                <h3>Dışarıdaysanız</h3>
              </div>
              <ul class="env-list">
                <li><span class="env-check ec-green" aria-hidden="true"><svg viewBox="0 0 12 12"><polyline points="1,6 4,9 11,3"/></svg></span><span>Bina, direk ve ağaçlardan uzaklaşın</span></li>
                <li><span class="env-check ec-green" aria-hidden="true"><svg viewBox="0 0 12 12"><polyline points="1,6 4,9 11,3"/></svg></span><span>Açık bir alana geçin, yere çökün</span></li>
                <li><span class="env-check ec-green" aria-hidden="true"><svg viewBox="0 0 12 12"><polyline points="1,6 4,9 11,3"/></svg></span><span>Araçtaysanız yavaşça durun, köprüden uzak bekleyin</span></li>
                <li><span class="env-check ec-green" aria-hidden="true"><svg viewBox="0 0 12 12"><polyline points="1,6 4,9 11,3"/></svg></span><span>Sarsıntı geçene kadar yerden kalkmayın</span></li>
              </ul>
            </div>
          </div>
        </section>

        <!-- 3. Deprem sonrası -->
        <section class="prep-section" id="after-tr">
          <div class="prep-section-title">
            <span class="prep-section-icon icon-after" aria-hidden="true">
              <svg viewBox="0 0 24 24"><path d="M22 11.08V12a10 10 0 11-5.93-9.14"/><path d="M22 4L12 14.01l-3-3"/></svg>
            </span>
            <h2>Deprem Sonrası</h2>
          </div>
          <div class="after-list" role="list">
            <div class="after-item" role="listitem">
              <span class="after-badge" aria-hidden="true"><svg viewBox="0 0 24 24"><path d="M18.36 6.64a9 9 0 1 1-12.73 0"/><line x1="12" y1="2" x2="12" y2="12"/></svg></span>
              <div class="after-text">
                <strong>Gaz, su ve elektriği kapatın</strong>
                <span>Gaz kokusu veya elektrik arızası varsa ana vanayı kapatıp binayı terk edin.</span>
              </div>
            </div>
            <div class="after-item" role="listitem">
              <span class="after-badge" aria-hidden="true"><svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg></span>
              <div class="after-text">
                <strong>Artçı sarsıntılara hazırlıklı olun</strong>
                <span>İlk depremden sonra saatler veya günler içinde artçılar gelebilir.</span>
              </div>
            </div>
            <div class="after-item" role="listitem">
              <span class="after-badge" aria-hidden="true"><svg viewBox="0 0 24 24"><path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/><line x1="9" y1="21" x2="9" y2="12"/><line x1="15" y1="21" x2="15" y2="12"/><line x1="3" y1="12" x2="21" y2="12"/></svg></span>
              <div class="after-text">
                <strong>Hasarlı binalara girmeyin</strong>
                <span>Çatlak veya hasar gördüğünüzde binayı terk edin ve güvenli mesafede bekleyin.</span>
              </div>
            </div>
            <div class="after-item" role="listitem">
              <span class="after-badge" aria-hidden="true"><svg viewBox="0 0 24 24"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 013.07 9.81 19.79 19.79 0 01.4 1.18 2 2 0 012 .99h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L6.91 8.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 15.99z"/></svg></span>
              <div class="after-text">
                <strong>Telefonu acil için saklayın</strong>
                <span>Hatları gereksiz yere meşgul etmeyin; acil durum iletişimini önceliklendirin.</span>
              </div>
            </div>
            <div class="after-item" role="listitem">
              <span class="after-badge" aria-hidden="true"><svg viewBox="0 0 24 24"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 00-3-3.87"/><path d="M16 3.13a4 4 0 010 7.75"/></svg></span>
              <div class="after-text">
                <strong>Aile toplanma noktasında buluşun</strong>
                <span>Önceden belirlenen noktaya gidin; AFAD ve resmi kanalları takip edin.</span>
              </div>
            </div>
          </div>
        </section>

        <footer class="prep-citation">
          <strong>Kaynaklar:</strong>
          <a href="https://www.afad.gov.tr/" target="_blank" rel="noopener noreferrer">AFAD</a>,
          <a href="http://www.koeri.boun.edu.tr/" target="_blank" rel="noopener noreferrer">Kandilli Rasathanesi</a>
        </footer>
      </div>
    </div>

    <!-- ── ENGLISH ── -->
    <div id="content-en" style="display:none;">
      <header class="prep-header">
        <h1>Earthquake Preparedness</h1>
        <p class="prep-lead">Earthquakes cannot be prevented, but preparation and safe behavior reduce harm. This page is for information only — follow official agency guidance.</p>
      </header>
      <div class="prep-body">
        <div class="prep-phases">
          <a href="#kit-en" class="prep-phase">
            <span class="prep-phase-num num-1">1</span>
            <div>
              <div class="prep-phase-label">Phase 1 — Before</div>
              <div class="prep-phase-name">Emergency Kit</div>
            </div>
          </a>
          <a href="#during-en" class="prep-phase">
            <span class="prep-phase-num num-2">2</span>
            <div>
              <div class="prep-phase-label">Phase 2 — During</div>
              <div class="prep-phase-name">Safe Behavior</div>
            </div>
          </a>
          <a href="#after-en" class="prep-phase">
            <span class="prep-phase-num num-3">3</span>
            <div>
              <div class="prep-phase-label">Phase 3 — After</div>
              <div class="prep-phase-name">Safe Recovery</div>
            </div>
          </a>
        </div>

        <section class="prep-section" id="kit-en">
          <div class="prep-section-title">
            <span class="prep-section-icon icon-kit" aria-hidden="true"><svg viewBox="0 0 24 24"><path d="M4 10a2 2 0 012-2h12a2 2 0 012 2v9a2 2 0 01-2 2H6a2 2 0 01-2-2v-9z"/><path d="M8 8V6a4 4 0 118 0v2"/></svg></span>
            <h2>Emergency Kit</h2>
          </div>
          <div class="kit-72h">
            <span class="kit-72h-icon">⚠️</span>
            <span>Help may be delayed for the first <strong>72 hours</strong>. Keep all supplies in one ready-to-grab bag.</span>
          </div>
          <div class="kit-categories" role="list">
            <div class="kit-cat" role="listitem">
              <div class="kit-cat-head"><span class="kit-cat-icon c-water" aria-hidden="true"><svg viewBox="0 0 24 24"><path d="M12 22a7 7 0 007-7c0-5-7-13-7-13S5 10 5 15a7 7 0 007 7z"/></svg></span><span class="kit-cat-name">Water &amp; Food</span></div>
              <ul class="kit-items">
                <li><span class="kit-bullet b-water"></span>Water (min 1 liter per person)</li>
                <li><span class="kit-bullet b-water"></span>Canned / non-perishable food</li>
                <li><span class="kit-bullet b-water"></span>Energy bars / biscuits</li>
                <li><span class="kit-bullet b-water"></span>Water purification tablets</li>
              </ul>
            </div>
            <div class="kit-cat" role="listitem">
              <div class="kit-cat-head"><span class="kit-cat-icon c-health" aria-hidden="true"><svg viewBox="0 0 24 24"><path d="M22 12h-4l-3 9L9 3l-3 9H2"/></svg></span><span class="kit-cat-name">Health &amp; Meds</span></div>
              <ul class="kit-items">
                <li><span class="kit-bullet b-health"></span>First aid kit</li>
                <li><span class="kit-bullet b-health"></span>Prescription medicines (7-day supply)</li>
                <li><span class="kit-bullet b-health"></span>Spare glasses / contact lens supplies</li>
                <li><span class="kit-bullet b-health"></span>Masks and gloves</li>
              </ul>
            </div>
            <div class="kit-cat" role="listitem">
              <div class="kit-cat-head"><span class="kit-cat-icon c-light" aria-hidden="true"><svg viewBox="0 0 24 24"><path d="M10 2h4v5l-1 1h-2l-1-1V2z"/><path d="M12 9v13M9 22h6"/></svg></span><span class="kit-cat-name">Light &amp; Comms</span></div>
              <ul class="kit-items">
                <li><span class="kit-bullet b-light"></span>Flashlight and spare batteries</li>
                <li><span class="kit-bullet b-light"></span>Portable charger (charged)</li>
                <li><span class="kit-bullet b-light"></span>Whistle</li>
                <li><span class="kit-bullet b-light"></span>Spare lighter / matches</li>
              </ul>
            </div>
            <div class="kit-cat" role="listitem">
              <div class="kit-cat-head"><span class="kit-cat-icon c-docs" aria-hidden="true"><svg viewBox="0 0 24 24"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><path d="M14 2v6h6M16 13H8M16 17H8M10 9H8"/></svg></span><span class="kit-cat-name">Docs &amp; Cash</span></div>
              <ul class="kit-items">
                <li><span class="kit-bullet b-docs"></span>ID / passport copy</li>
                <li><span class="kit-bullet b-docs"></span>Insurance documents</li>
                <li><span class="kit-bullet b-docs"></span>Emergency cash</li>
                <li><span class="kit-bullet b-docs"></span>Family meeting point note</li>
              </ul>
            </div>
          </div>
        </section>

        <section class="prep-section" id="during-en">
          <div class="prep-section-title">
            <span class="prep-section-icon icon-during" aria-hidden="true"><svg viewBox="0 0 24 24"><path d="M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"/><path d="M12 9v4M12 17h.01"/></svg></span>
            <h2>During an Earthquake</h2>
          </div>
          <p class="steps-intro">Stay calm. Follow the internationally recognized <strong>Drop, Cover, and Hold On</strong> method.</p>
          <div class="steps-row" role="list">
            <div class="step-card" role="listitem">
              <div class="step-num s1">1</div>
              <div class="step-visual" aria-hidden="true">
                <svg viewBox="0 0 80 80" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" style="color:var(--accent-gold)">
                  <circle cx="40" cy="13" r="7"/><path d="M40 20 Q37 32 34 42"/><path d="M37 29 L18 38"/><path d="M37 29 L56 36"/>
                  <path d="M34 42 L22 58"/><path d="M34 42 L48 56"/>
                  <line x1="8" y1="64" x2="72" y2="64" stroke-width="1.5" stroke-dasharray="4 3"/>
                  <path d="M10 18 L10 30 M6 26 L10 30 L14 26" stroke-width="1.8"/>
                  <path d="M70 18 L70 30 M66 26 L70 30 L74 26" stroke-width="1.8"/>
                </svg>
              </div>
              <div class="step-keyword">DROP</div>
              <div class="step-sub">Get down on hands and knees immediately</div>
            </div>
            <div class="step-card" role="listitem">
              <div class="step-num s2">2</div>
              <div class="step-visual" aria-hidden="true">
                <svg viewBox="0 0 80 80" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" style="color:var(--accent-blue)">
                  <rect x="10" y="20" width="60" height="7" rx="2"/><line x1="16" y1="27" x2="16" y2="60"/><line x1="64" y1="27" x2="64" y2="60"/>
                  <circle cx="40" cy="38" r="7"/><path d="M33 34 Q25 26 23 32"/><path d="M47 34 Q55 26 57 32"/>
                  <path d="M40 45 L38 58"/><path d="M40 45 L43 58"/>
                  <line x1="8" y1="64" x2="72" y2="64" stroke-width="1.5" stroke-dasharray="4 3"/>
                </svg>
              </div>
              <div class="step-keyword">COVER</div>
              <div class="step-sub">Cover your head and neck with your arms</div>
            </div>
            <div class="step-card" role="listitem">
              <div class="step-num s3">3</div>
              <div class="step-visual" aria-hidden="true">
                <svg viewBox="0 0 80 80" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" style="color:var(--accent-green)">
                  <rect x="10" y="20" width="60" height="7" rx="2"/><line x1="16" y1="27" x2="16" y2="60"/><line x1="64" y1="27" x2="64" y2="60"/>
                  <circle cx="34" cy="38" r="7"/><path d="M34 45 L32 58"/><path d="M34 45 L37 58"/>
                  <path d="M27 35 L16 28" stroke-width="2.8"/><path d="M27 41 L16 41" stroke-width="2.8"/>
                  <circle cx="16" cy="28" r="3.5"/><circle cx="16" cy="41" r="3.5"/>
                  <path d="M62 32 Q68 29 66 36 Q64 43 70 41" stroke-width="1.4"/>
                  <line x1="8" y1="64" x2="72" y2="64" stroke-width="1.5" stroke-dasharray="4 3"/>
                </svg>
              </div>
              <div class="step-keyword">HOLD ON</div>
              <div class="step-sub">Hold on until shaking stops completely</div>
            </div>
          </div>
          <div class="env-split">
            <div class="env-card">
              <div class="env-card-head"><span class="env-card-icon e-indoor" aria-hidden="true"><svg viewBox="0 0 24 24"><path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/><path d="M9 22V12h6v10"/></svg></span><h3>If You Are Indoors</h3></div>
              <ul class="env-list">
                <li><span class="env-check ec-blue" aria-hidden="true"><svg viewBox="0 0 12 12"><polyline points="1,6 4,9 11,3"/></svg></span><span>Drop, Cover, Hold On next to sturdy furniture</span></li>
                <li><span class="env-check ec-blue" aria-hidden="true"><svg viewBox="0 0 12 12"><polyline points="1,6 4,9 11,3"/></svg></span><span>Stay away from windows and balconies</span></li>
                <li><span class="env-check ec-blue" aria-hidden="true"><svg viewBox="0 0 12 12"><polyline points="1,6 4,9 11,3"/></svg></span><span>Do not use elevators or stairs during shaking</span></li>
                <li><span class="env-check ec-blue" aria-hidden="true"><svg viewBox="0 0 12 12"><polyline points="1,6 4,9 11,3"/></svg></span><span>Do not run outside until shaking stops</span></li>
              </ul>
            </div>
            <div class="env-card">
              <div class="env-card-head"><span class="env-card-icon e-outdoor" aria-hidden="true"><svg viewBox="0 0 24 24"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg></span><h3>If You Are Outdoors</h3></div>
              <ul class="env-list">
                <li><span class="env-check ec-green" aria-hidden="true"><svg viewBox="0 0 12 12"><polyline points="1,6 4,9 11,3"/></svg></span><span>Move away from buildings, poles, and trees</span></li>
                <li><span class="env-check ec-green" aria-hidden="true"><svg viewBox="0 0 12 12"><polyline points="1,6 4,9 11,3"/></svg></span><span>Move to open ground and drop</span></li>
                <li><span class="env-check ec-green" aria-hidden="true"><svg viewBox="0 0 12 12"><polyline points="1,6 4,9 11,3"/></svg></span><span>In a vehicle: stop away from overpasses</span></li>
                <li><span class="env-check ec-green" aria-hidden="true"><svg viewBox="0 0 12 12"><polyline points="1,6 4,9 11,3"/></svg></span><span>Stay down until shaking fully stops</span></li>
              </ul>
            </div>
          </div>
        </section>

        <section class="prep-section" id="after-en">
          <div class="prep-section-title">
            <span class="prep-section-icon icon-after" aria-hidden="true"><svg viewBox="0 0 24 24"><path d="M22 11.08V12a10 10 0 11-5.93-9.14"/><path d="M22 4L12 14.01l-3-3"/></svg></span>
            <h2>After an Earthquake</h2>
          </div>
          <div class="after-list" role="list">
            <div class="after-item" role="listitem">
              <span class="after-badge" aria-hidden="true"><svg viewBox="0 0 24 24"><path d="M18.36 6.64a9 9 0 1 1-12.73 0"/><line x1="12" y1="2" x2="12" y2="12"/></svg></span>
              <div class="after-text"><strong>Turn off gas, water, and electricity</strong><span>If you smell gas or see electrical damage, shut off the main valve and leave the building.</span></div>
            </div>
            <div class="after-item" role="listitem">
              <span class="after-badge" aria-hidden="true"><svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg></span>
              <div class="after-text"><strong>Expect aftershocks</strong><span>Aftershocks can occur hours or days after the main event — stay alert.</span></div>
            </div>
            <div class="after-item" role="listitem">
              <span class="after-badge" aria-hidden="true"><svg viewBox="0 0 24 24"><path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/><line x1="9" y1="21" x2="9" y2="12"/><line x1="15" y1="21" x2="15" y2="12"/><line x1="3" y1="12" x2="21" y2="12"/></svg></span>
              <div class="after-text"><strong>Stay out of damaged buildings</strong><span>If you see cracks or structural damage, leave and keep a safe distance.</span></div>
            </div>
            <div class="after-item" role="listitem">
              <span class="after-badge" aria-hidden="true"><svg viewBox="0 0 24 24"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 013.07 9.81 19.79 19.79 0 01.4 1.18 2 2 0 012 .99h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L6.91 8.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 15.99z"/></svg></span>
              <div class="after-text"><strong>Keep phones free for emergencies</strong><span>Avoid unnecessary calls; keep lines open for rescue services.</span></div>
            </div>
            <div class="after-item" role="listitem">
              <span class="after-badge" aria-hidden="true"><svg viewBox="0 0 24 24"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 00-3-3.87"/><path d="M16 3.13a4 4 0 010 7.75"/></svg></span>
              <div class="after-text"><strong>Meet at your family's rally point</strong><span>Go to your pre-arranged meeting point and follow FEMA / official agency channels.</span></div>
            </div>
          </div>
        </section>

        <footer class="prep-citation">
          <strong>Sources:</strong>
          <a href="https://www.fema.gov/" target="_blank" rel="noopener noreferrer">FEMA</a>,
          <a href="https://www.usgs.gov/" target="_blank" rel="noopener noreferrer">USGS</a>
        </footer>
      </div>
    </div>

